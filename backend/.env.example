# Allowed frontend origins (comma-separated)
# Local development:
ALLOWED_ORIGINS=http://localhost:3000

# Production (add your Vercel URL):
# ALLOWED_ORIGINS=https://mlinsights.vercel.app,http://localhost:3000

# Directory for session uploads
# Local development: leave blank (defaults to backend/uploads/)
# UPLOAD_DIR=

# Production on Render (ephemeral writable temp dir):
# UPLOAD_DIR=/tmp/mlinsights_uploads
